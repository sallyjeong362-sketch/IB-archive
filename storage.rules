rules_version = '2';

// 수업자료 아카이브 - Storage 보안 규칙
// Firebase 콘솔 > Storage > 규칙 탭에 이 내용을 붙여넣고 게시하세요.
service firebase.storage {
  match /b/{bucket}/o {
    // 교재 표지 이미지
    match /textbook-covers/{textbookId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // 자료 첨부 파일/이미지 (교재 > 유닛 > 게시물 경로별로 저장)
    match /uploads/{textbookId}/{unitId}/{postId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
  }
}
